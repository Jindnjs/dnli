  "applications": {
    "overview": "국가 건설행정 시스템(세움터 등), 공간정보 기반 분석·시뮬레이션·운영 분야",
    "cards": [
      {
        "title": "수집 가이드라인 도입을 통한 공간 정보 운영 데이터셋 구축",
        "current": "크라우드 소싱으로 취득되는 다종 시계열 공간데이터의 규격과 포맷이 일관되지 않아, 국가 건설행정 시스템(세움터 등)과 연계하거나 오픈 API 환경에서 도시 문제의 실시간 분석에 한계가 있음",
        "improved": "데이터 취득 가이드라인 적용 및 클라우드 기반 API 제공을 통해 규격화된 고품질 데이터를 구축함으로써, 실시간 도시 문제 파악 및 인프라 노후화를 예방하는 공공 유지보수 시스템에 활용 가능"
      },
      {
        "title": "스마트 건설 및 디지털 트윈 시계열 데이터 플랫폼 활용",
        "current": "민간 기업은 전문 인력 부족과 상용 공간 DBMS의 높은 구축 비용으로 인해, 드론이나 각종 센서에서 수집되는 대용량 비정형 데이터를 시계열 공간 데이터로 통합 관리하고 분석하는 데 어려움이 있음",
        "improved": "직관적인 UI와 라이선스 비용 없는 오픈소스 기반의 경제적인 통합 연계 구조가 제공됨으로써, 스마트 건설, 디지털 트윈 구현 및 AI 이상 감지 모델 학습을 위한 백엔드 플랫폼으로 즉각 활용 가능"
      }
    ]
  },
