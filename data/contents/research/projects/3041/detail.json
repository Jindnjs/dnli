  "applications": {
    "overview": "디지털 트윈 플랫폼 / 스마트시티 / 도시계획 시뮬레이션 분야",
    "cards": [
      {
        "title": "부산·서울(S-Map) / 글로벌 디지털 트윈",
        "current": "플랫폼 관리자가 도시 3D 모델을 조회할 때, 대용량 데이터로 인해 로딩 및 시각화 속도가 저하되어 실시간 활용이 어려움",
        "improved": "3D Tiles 기반 분할 로딩과 데이터 경량화를 적용해 초기 로딩 3초 이내, 데이터 용량 90% 이상 감소를 달성하여, 도시 3D 모델의 실시간 조회 가능"
      },
      {
        "title": "중앙재난안전상황실 / 지자체 통합관제센터",
        "current": "재난 발생 시 3D 지도 로딩 지연으로 침수·화재·지진 상황을 즉시 확인하기 어려워 대응 판단이 지연됨",
        "improved": "경량화된 3D 데이터 시각화를 통해 재난 지역을 즉시 확인할 수 있어 재난 상황 분석 및 대응 시간을 약 60% 단축 가능"
      },
      {
        "title": "LH 스마트시티 / 지자체 도시계획과",
        "current": "도시 3D 분석을 위해 고사양 PC 기반 오프라인 프로그램을 사용해야 하여 현장 또는 협업 환경에서 활용이 제한됨",
        "improved": "웹 브라우저 기반 3D 시각화를 통해 별도 프로그램 없이 도시 모델을 조회하고, 일조·조망·경관·수목 배치 시뮬레이션을 실시간으로 수행할 수 있음"
      }
    ]
  },
