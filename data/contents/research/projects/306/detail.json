  "applications": {
    "overview": "디지털 국토정보 플랫폼(연구 통합 플랫폼)",
    "cards": [
      {
        "title": "연구 통합 플랫폼에 건설정보 데이터 연계 기반 제공",
        "current": "건설정보는 설계·시공 관리의 목적으로 수작업 변환 또는 개별 포맷 기반 연계에 의존하고 있어 데이터 연계의 일관성 부족 및 재사용·확장에 한계가 존재함",
        "improved": "연계 표준이 적용된 연구 통합 플랫폼에서는 건설정보를 공간정보 구조에 부합하는 객체 단위로 자동 변환할 수 있어 건설정보 연계 기반 마련 및 건설정보를 NDT 표준*과의 호환성 확보가 가능<br><br> * 국가 디지털 트윈(NDT) 표준 : 건물, 교통, 지하 공간 등 국토 공간정보를 3차원 디지털 세상에 구현하고 표준화하여 통합하는 사업"
      },
      {
        "title": "연구 통합 플랫폼에 건설정보 시뮬레이션·분석 기반 제공",
        "current": "기존 공간정보 플랫폼들은 주로 외부 공간 중심의 3차원 공간정보를 활용하고 있어, 건물 내부 구조나 상세 설비 정보의 반영에는 제약이 존재함",
        "improved": "본 연구에서 제시하는 변환 표준을 적용하여 연구 통합 플랫폼에서 건물 단위·공간 단위 시뮬레이션 및 분석·활용할 수 있는 기반 제공"
      }
    ]
  },
