  "applications": {
    "overview": "국토지리정보원, 공간정보를 활용하여 새로운 서비스를 개발하는 분야",
    "cards": [
      {
        "title": "3차원 공간정보 구축사업, 정밀도 도로 지도 융합, 건축물 인허가 방식 고도화",
        "current": "공간정보 구축된 국가공간정보DB 갱신기술에 관한 공공 데이터 서비스 부족",
        "improved": "DEM, 3D 모델의 성과물 품질 검수 및 RMSE 산정식 검토에 관한 서비스 제공 혹은 이를 이용한 데이터 신뢰도를 제시하여 3차원 공간정보 구축사업 추진상의 목표 데이터 품질 기준점 마련"
      },
      {
        "title": "민간에서의 일반적으로 사용 가능한 고정밀/저비용 공간데이터 취득 수집 및 분석",
        "current": "공간정보 구축된 국가공간정보DB 갱신기술에 관한 민간 데이터 서비스 부족",
        "improved": "인접 데이터를 통한 정합 기술을 통해 데이터 부분갱신, 분석 등으로 활용 가능하며, 수치화된 정합 내역 자료 제공으로 데이터 분석 업무 보조 가능"
      }
    ]
  },
