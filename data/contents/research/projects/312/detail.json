  "applications": {
    "overview": "국가 R&D 연구 통합 플랫폼, 공공 클라우드 플랫폼, 공간정보 테스트베드 분야",
    "cards": [
      {
        "title": "디지털 국토정보 기술개발 사업 4개 핵심 연구 통합 실증",
        "current": "연구자가 위성영상 분석, 공간DB 구축, AI 분석 등 핵심 연구 성과를 검증하려면 서로 다른 실험 환경에서 개별 시험을 수행해야 해 통합 검증에 시간이 많이 소요됨",
        "improved": "클라우드 기반 통합 테스트베드에서 핵심 연구기술을 하나의 실증 환경에서 연계 검증할 수 있어 연구 통합 검증 시간이 약 60% 단축"
      },
      {
        "title": "AI/ML 연구, 대용량 3D데이터 처리",
        "current": "AI 학습과 대용량 3D 데이터 분석 시 GPU 사용 현황을 실시간 확인하기 어려워 GPU 자원 활용 효율이 낮고 대기 시간이 발생함",
        "improved": "NVIDIA MIG 기술을 활용해 GPU를 논리적으로 분할하여 여러 연구자가 동시에 사용할 수 있어 GPU 자원 활용률 약 70% 이상 향상 <br><br>*Multi-Instance GPU"
      },
      {
        "title": "V-World / K-GeoP 등 국가 공간정보 플랫폼",
        "current": "V-World와 K-GeoP 등 국가 공간정보 플랫폼을 연계하려면 표준이 달라 플랫폼별 개별 연계 개발이 필요해 데이터 연계에 시간이 많이 소요됨",
        "improved": "OGC 표준 API 기반 연계를 적용해 동일 방식으로 플랫폼을 연동할 수 있어 데이터 연계 개발 시간이 약 70% 이상 단축"
      }
    ]
  },
