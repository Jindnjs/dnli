  "applications": {
    "overview": "디지털 트윈국토 플랫폼 / 스마트시티 분야",
    "cards": [
      {
        "title": "국가·지자체 공간정보 플랫폼 운영 분야",
        "current": "V-World 등 공간정보 플랫폼 관리자가 3D 데이터를 CityGML 형식으로 변환하려 할 때 외산 상용 도구(FME)에 의존해야 하며, 최신 CityGML 3.0 변환을 지원하지 않아 최신 데이터 활용에 한계가 있음",
        "improved": "자동 변환 파이프라인을 적용해 외산 도구 없이 CityGML 3.0 기반 변환·통합이 가능해지며, 데이터 변환 작업 시간이 약 70% 이상 단축되어 공간정보 정책 활용 효율 향상"
      },
      {
        "title": "스마트시티·도시개발 디지털트윈 구축·운영 분야",
        "current": "스마트시티 구축 시 건물·도로·지하시설 등 다양한 3D 데이터를 플랫폼에 적용하려면 데이터 형식이 달라 수동 정합·변환 작업을 반복해야 하며 구축 기간이 길어짐",
        "improved": "자동 데이터 파이프라인을 통해 다양한 3D 데이터를 표준 형식으로 자동 통합하여 데이터 구축 시간이 기존 대비 약 60% 이상 단축되고 디지털트윈 운영 효율 향상"
      }
    ]
  },
