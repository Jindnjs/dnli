  "applications": {
    "overview": "(지방자치단체·중앙행정기관/스마트시) 공간 데이터 시각화 및 분석",
    "cards": [
      {
        "title": "주행/보행 환경 분석 / 주요 과밀 지역 모니터링 및 예측",
        "current": "이면도로 등 취약지역에 대한 모니터링 및 예측, 의사결정을 지원하는 시스템이 부족",
        "improved": "동적주제도를 기반으로 주행/보행환경 위험지역 및 과밀지역에 대한 모니터링 및 위험 예측 판단으로 의사결정을 지원함"
      },
      {
        "title": "준실시간 시민 생활권 동적정보/동적주제도 분석 / 스마트 시티 프로젝트 지원",
        "current": "공공‧민간에서의 3D 공간 데이터 시각화 SW 및 플랫폼 부족, 시민 생활권 내 준실시간 정보 취득 SW 및 플랫폼 부족",
        "improved": "대규모 3D 데이터 실시간 시각화 기능을 통해 시민 생활권 내 다양한 도시문제 분석의 정확성을 높임"
      }
    ]
