  "applications": {
    "overview": "디지털 트윈 기반 도시관리·공간정보 기반 분석·시뮬레이션 분야",
    "cards": [
      {
        "title": "항공·드론 정사영상 통합을 통한 국토 공간정보 갱신 활용",
        "current": "광학·IR 등 분광정보 및 해상도가 상이한 이종 센서 영상 간 직접 매칭 시 오매칭 발생으로 2차원 공간정보 생산 정확도 저하",
        "improved": "에지 강화 합성 영상 및 어파인 변환 기반 특징점 매칭을 통해 이종 센서 영상 간 정합 정확도를 향상시켜, 기존 1~2년 주기의 항공정사영상 갱신을 고해상도 드론 영상으로 단주기 자동 갱신 가능"
      },
      {
        "title": "드론·로봇 다중 센서 데이터 통합을 통한 재난 대응 및 실시간 모니터링 활용",
        "current": "드론, 위성, 항공 등 다양한 센서 기반 데이터가 개별 관리되어 재난 상황 시 통합 분석 및 신속 대응에 한계 존재",
        "improved": "히스토그램 매칭 및 어파인 변환 기반 자동 정합 기술을 적용하여 다중 센서 데이터를 실시간 통합, 재난 대응 시뮬레이션 및 피해지역 모니터링 정밀도 향상 가능"
      }
    ]
