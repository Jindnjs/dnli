  "applications": {
    "overview": "공공데이터 통합 관리 및 개방 분야, AI.빅데이터 분석 활용",
    "cards": [
      {
        "title": "공공데이터 활용 편의성 향상",
        "current": "사용자는 국가 데이터 포털이나 기관별 시스템에 개별적으로 접속해 데이터를 검색·확인해야 하므로 데이터 탐색에 많은 시간이 소요됨. 또한 기관별 제공 방식 차이로 업무 부담이 가중되는 문제가 발생",
        "improved": "여러 기관의 데이터를 단일 창구에서 통합 검색·확인할 수 있어 데이터 탐색 시간을 단축하고, 기관별 이질성으로 인한 업무 부담을 크게 완화할 수 있음"
      },
      {
        "title": "공공데이터 품질 및 신뢰성 확보",
        "current": "공공데이터 활용 시 메타데이터*를 별도로 확인해야 하고, 기관별 데이터 형식이 상이하여 분석 및 시스템 연계를 위해 반복적인 변환 작업이 필요 <br><br>*메타데이터:데이터 생상 기관, 생성 시점, 갱신 여부, 품질 정보, 공간정보 메타데이터 표준 항목등",
        "improved": "데이터 제공 기관이 표준 기반 메타데이터를 함께 관리·제공함으로써 데이터 해석의 일관성과 신뢰성을 높이고, 별도의 변환 없이 분석 및 서비스에 바로 활용할 수 있음"
      }
    ]
  },
