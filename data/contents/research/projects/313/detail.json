  "applications": {
    "overview": "연구자 통합 포털, 공공 클라우드 플랫폼",
    "cards": [
      {
        "title": "통합 테스트베드 기반 연구 인프라 운영",
        "current": "연구자가 실험 환경을 구축하려면 서버·VM 자원을 개별 설정해야 해 환경 구축과 자원 재배치에 시간이 많이 소요되고 장애 발생 시 원인 파악이 어려움",
        "improved": "통합 테스트베드 플랫폼에서 VM·네트워크 자원을 중앙 관리하여 연구 환경 구축 시간이 기존 대비 약 70% 단축되고 실시간 모니터링으로 장애 대응 속도 향상"
      },
      {
        "title": "디지털 국토정보 기술개발 사업 참여 연구기관",
        "current": "연구자가 3D 건물 데이터를 활용하려면 기관별 계정과 서버에 각각 접속해야 해 연구 환경 준비에 평균 1~2시간 소요됨",
        "improved": "웹 기반 통합 포털과 단일 로그인(SSO)을 적용해 한 번 로그인으로 VM·데이터 접근이 가능해져 연구 환경 준비 시간이 약 80% 이상 단축"
      },
      {
        "title": "TTA 공인시험기관 인증 / 성과물 품질 검증",
        "current": "연구 성과물 검증과 시험이 수작업으로 진행되어 테스트 준비와 환경 구성에 시간이 오래 걸리고 반복 시험 시 비용 부담 발생",
        "improved": "CI/CD 기반 자동 빌드·시험·배포 체계를 구축해 시험 준비 시간을 기존 대비 약 60% 단축하고 표준화된 검증 프로세스로 인증 대응 효율 향상"
      }
    ]
  },
