  "applications": {
    "overview": "국가 공간정보 포털, 자자체 공간정보 분야, 민간활용 분야",
    "cards": [
      {
        "title": "V-World 데이터 카탈로그",
        "current": "플랫폼 관리자가 특정 지역의 3D 건물 데이터를 찾으려면 건물·지역·시점·LOD 조건을 개별 시스템에서 순차 조회해야 해 데이터 탐색에 약 3시간 이상 소요됨.",
        "improved": "GeoDCAT 기반 데이터 카탈로그를 적용해 지역·시점·LOD를 통합 조건으로 한 번에 검색할 수 있어 데이터 탐색 시간이 약 30분 이내로 단축(약 85% 감소)."
      },
      {
        "title": "국가공간정보포털",
        "current": "3D 건물 데이터와 시점·LOD 정보가 분리 관리되어 과거·최신 데이터를 비교하려면 관리 대장을 수작업으로 대조해야 하고, 외부 시스템 연계를 위해 별도 변환 작업이 필요해 연계 준비에 약 2~3시간 소요됨.",
        "improved": "메타데이터 자동 연계를 통해 시점·LOD별 데이터가 단일 카탈로그에서 관리되며, OGC 표준 API 기반 연동으로 외부 시스템 연계 준비 시간이 약 1시간 이내로 단축(약 70% 감소)."
      }
    ]
  },
